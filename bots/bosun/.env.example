# Required environment variables for the bosun governance snapshot bot.
# Copy this file to bots/bosun/.env (or keep it at the project root as .env)
# and fill in the real values. Never commit the filled-in file.

# JSON-RPC endpoint for the target EVM chain (Sepolia or anvil).
PACTO_GOVERNANCE_RPC_URL=

# Bot identity registered with the daemon.
PACTO_GOVERNANCE_BOT_ID=bosun

# MLS Squad group id to post snapshots into.
PACTO_GOVERNANCE_GROUP_ID=

# Daemon transport (Unix socket is the default for the compose stack).
PACTO_GOVERNANCE_DAEMON_SOCKET=/run/pacto/pacto-bot-api.sock
# For HTTP transport, comment the socket line and uncomment these:
# PACTO_GOVERNANCE_DAEMON_HTTP=
# PACTO_GOVERNANCE_HTTP_SECRET=

# Optional settings
# PACTO_GOVERNANCE_CADENCE_SECONDS=86400
# PACTO_GOVERNANCE_SQUAD_INDEX=0
# PACTO_GOVERNANCE_CAPTAIN=0x0000000000000000000000000000000000000000
# PACTO_GOVERNANCE_CREW_CANDIDATES=
# PACTO_GOVERNANCE_PROPOSER_CANDIDATES=
# PACTO_GOVERNANCE_REGISTRY=0x45127C1c92741C0dA38e1A73fbb97a8a2C46770f
# PACTO_GOVERNANCE_HATS=0x3bc1A0Ad72417f2d411118085256fC53CBdDd137

# PACTO_LOG_LEVEL=info
